# Environment Variables Configuration
# Copy this file to .env.local and fill in your values

# Supabase Configuration (Optional - for cloud sync)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google AI (Optional - for AI insights)
VITE_GOOGLE_API_KEY=your_google_api_key_here

# OpenCode Go API (Recommended - GLM-5 for institutional-grade analysis)
VITE_OPENCODE_API_KEY=your_opencode_api_key_here

# GLM-5 AI (Alternative - BigModel endpoint)
VITE_GLM_API_KEY=your_glm_api_key_here

# Gemini API (Alternative - for portfolio analysis)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Application Settings
VITE_APP_TITLE=Atlas Portfolio Manager
VITE_APP_VERSION=2.0.1

# Feature Flags
VITE_ENABLE_CLOUD_SYNC=false
VITE_ENABLE_AI_INSIGHTS=false
VITE_ENABLE_ANALYTICS=false

# Security
VITE_ENABLE_ENCRYPTION=false
VITE_ENCRYPTION_KEY=your_32_character_encryption_key_here
